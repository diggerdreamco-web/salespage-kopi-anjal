# ToyyibPay Configuration
# Set these in Cloudflare Dashboard > Pages > Settings > Environment Variables

# Your ToyyibPay User Secret Key
# Dapatkan dari: https://toyyibpay.com > Login > Tetapan Akaun
TOYYIBPAY_SECRET_KEY=your-secret-key-here

# Your ToyyibPay Category Code
# Dapatkan dari: https://toyyibpay.com > Login > Kategori > Cipta Kategori
TOYYIBPAY_CATEGORY_CODE=your-category-code-here

# Your site URL (tanpa trailing slash)
SITE_URL=https://kopianjal.com

# Google Sheets Webhook URL
# Dapatkan dari: Google Apps Script > Deploy > Web App > Copy URL
# Rujuk file google-apps-script.js untuk setup
GOOGLE_SHEET_WEBHOOK=https://script.google.com/macros/s/xxx/exec
